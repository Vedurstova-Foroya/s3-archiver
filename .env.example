S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY=replace-me
S3_SECRET_KEY=replace-me
S3_REGION=eu-frankfurt-1
# Source and destination buckets shared by every route in ARCHIVER_CONFIG_JSON.
# A route only needs its own "bucket" in source/destination when it should use a
# bucket other than these defaults.
S3_SOURCE_BUCKET=bucket-20260612-1008-s3-archiver-staging-2
S3_DESTINATION_BUCKET=bucket-20260615-0910-s3-archiver-staging-3
ARCHIVER_RUN_TIMEOUT=7d
ARCHIVER_TEMP_DIR=/mnt/data/tmp/s3-archiver
ARCHIVER_MAX_SOURCE_OBJECT_SIZE_MIB=102400
ARCHIVER_MAX_DESTINATION_ARCHIVE_SIZE_MIB=102400
# Set CLEANUP=true to delete archived source objects automatically after each
# scheduled/automatic archive run. Defaults to false. The manual
# `s3-archiver cleanup` command ignores this and always cleans up.
CLEANUP=false
# Set ARCHIVER_BUCKET_WHITELIST_ENABLED=true to require every source and
# destination bucket in ARCHIVER_CONFIG_JSON to appear in
# ARCHIVER_BUCKET_WHITELIST (a JSON array of bucket names); startup fails
# otherwise. Defaults to false (no check). With the check enabled an empty
# list rejects every bucket, so nothing can run.
ARCHIVER_BUCKET_WHITELIST_ENABLED=false
ARCHIVER_BUCKET_WHITELIST=["bucket-20260612-1008-s3-archiver-staging-2", "bucket-20260615-0910-s3-archiver-staging-3"]
LOG_LEVEL=INFO
LOG_DIR=/var/log/s3-archiver
# Most routes use an empty "destination": {} - the minimal archive form. It
# inherits the bucket from S3_DESTINATION_BUCKET and the path from the source, so
# objects archive under the same prefix on the destination bucket. The last route
# (wrf-ecmwf) sets "bucket" and "path" explicitly to override those defaults.
ARCHIVER_CONFIG_JSON='[
  {
    "name": "harmonie",
    "parser": "filename_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "data/harmonie/processor/"},
    "destination": {}
  },
  {
    "name": "harmonie-download",
    "parser": "filename_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "data/harmonie_download/"},
    "destination": {}
  },
  {
    "name": "fvcom",
    "parser": "filename_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "data/fvcom/current_web_img/hav/"},
    "destination": {}
  },
  {
    "name": "fae",
    "parser": "folder_timestamp",
    "copy_mode": "daily_tar_gz",
    "source": {"path": "data/fae"},
    "destination": {}
  },
  {
    "name": "wrf-ecmwf",
    "parser": "folder_timestamp_child",
    "copy_mode": "timestamp_child_tar_gz",
    "source": {"bucket": "bucket-20260612-1008-s3-archiver-staging-2", "path": "data/wrf/ecmwf/"},
    "destination": {"bucket": "bucket-20260615-0910-s3-archiver-staging-3", "path": "data/wrf/ecmwf/"}
  }
]'
